{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.base.json", "vitest.config.ts"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "migrate": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "migrate:status": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "bootstrap-admin": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
